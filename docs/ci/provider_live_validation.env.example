# Backend live provider validation smoke tests
#
# These are opt-in, read-only smoke tests intended for minimal-cost release validation.
# They do not create, mutate, or delete provider resources.
# Each provider test performs only:
#   1. profile connectivity check
#   2. object listing against an existing bucket/container with maxKeys=1
#
# Run example:
#   cd backend
#   set -a; source ../docs/ci/provider_live_validation.env.example; set +a
#   go test ./internal/api -run 'TestLiveValidation(AwsS3|GcpGcs|AzureBlob|OciObjectStorage|MinioS3Compatible|CephS3Compatible)$'

# AWS S3
S3DESK_LIVE_AWS_BUCKET=
S3DESK_LIVE_AWS_REGION=
S3DESK_LIVE_AWS_ACCESS_KEY_ID=
S3DESK_LIVE_AWS_SECRET_ACCESS_KEY=
S3DESK_LIVE_AWS_SESSION_TOKEN=
S3DESK_LIVE_AWS_ENDPOINT=
S3DESK_LIVE_AWS_FORCE_PATH_STYLE=0
S3DESK_LIVE_AWS_TLS_SKIP_VERIFY=0

# Google Cloud Storage
S3DESK_LIVE_GCS_BUCKET=
S3DESK_LIVE_GCS_SERVICE_ACCOUNT_JSON=
S3DESK_LIVE_GCS_PROJECT_NUMBER=
S3DESK_LIVE_GCS_ENDPOINT=
S3DESK_LIVE_GCS_ANONYMOUS=0
S3DESK_LIVE_GCS_TLS_SKIP_VERIFY=0

# Azure Blob Storage
S3DESK_LIVE_AZURE_CONTAINER=
S3DESK_LIVE_AZURE_ACCOUNT_NAME=
S3DESK_LIVE_AZURE_ACCOUNT_KEY=
S3DESK_LIVE_AZURE_ENDPOINT=
S3DESK_LIVE_AZURE_USE_EMULATOR=0
S3DESK_LIVE_AZURE_TLS_SKIP_VERIFY=0

# OCI Object Storage
S3DESK_LIVE_OCI_BUCKET=
S3DESK_LIVE_OCI_REGION=
S3DESK_LIVE_OCI_NAMESPACE=
S3DESK_LIVE_OCI_COMPARTMENT=
S3DESK_LIVE_OCI_ENDPOINT=
S3DESK_LIVE_OCI_AUTH_PROVIDER=
S3DESK_LIVE_OCI_CONFIG_FILE=
S3DESK_LIVE_OCI_CONFIG_PROFILE=
S3DESK_LIVE_OCI_TLS_SKIP_VERIFY=0

# Local MinIO (S3-compatible)
S3DESK_LIVE_MINIO_BUCKET=
S3DESK_LIVE_MINIO_ENDPOINT=
S3DESK_LIVE_MINIO_PUBLIC_ENDPOINT=
S3DESK_LIVE_MINIO_REGION=us-east-1
S3DESK_LIVE_MINIO_ACCESS_KEY_ID=
S3DESK_LIVE_MINIO_SECRET_ACCESS_KEY=
S3DESK_LIVE_MINIO_FORCE_PATH_STYLE=1
S3DESK_LIVE_MINIO_TLS_SKIP_VERIFY=0

# Local Ceph RGW (S3-compatible)
S3DESK_LIVE_CEPH_BUCKET=
S3DESK_LIVE_CEPH_ENDPOINT=
S3DESK_LIVE_CEPH_PUBLIC_ENDPOINT=
S3DESK_LIVE_CEPH_REGION=us-east-1
S3DESK_LIVE_CEPH_ACCESS_KEY_ID=
S3DESK_LIVE_CEPH_SECRET_ACCESS_KEY=
S3DESK_LIVE_CEPH_FORCE_PATH_STYLE=1
S3DESK_LIVE_CEPH_TLS_SKIP_VERIFY=0
