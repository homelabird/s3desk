# Remote/Postgres deployment example for docker compose.
# Copy to `.env` and replace placeholder values before `docker compose up -d`.

# Container image to deploy
S3DESK_IMAGE=ghcr.io/homelabird/s3desk
S3DESK_TAG=0.21v-rc1

# Host bind for the published HTTP port
# Examples:
#   S3DESK_BIND_ADDRESS=127.0.0.1
#   S3DESK_BIND_ADDRESS=0.0.0.0
S3DESK_BIND_ADDRESS=127.0.0.1
S3DESK_PORT=8080

# Required for remote deployment
API_TOKEN=replace-with-a-long-random-token
POSTGRES_PASSWORD=replace-with-a-strong-db-password

# Optional Postgres overrides
POSTGRES_USER=s3desk
POSTGRES_DB=s3desk

# Required when you expose S3Desk behind a reverse proxy or hostname.
# This should be the browser-facing origin users open.
# Example:
#   EXTERNAL_BASE_URL=https://s3desk.example.com
EXTERNAL_BASE_URL=

# Required only for non-private hostnames.
# Example:
#   ALLOWED_HOSTS=s3desk.example.com
ALLOWED_HOSTS=
