# Full compose environment template.
# Most users only need the "Core Remote / Postgres Deployment" section.
# Optional sections below are only for the matching compose stacks.

# -----------------------------------------------------------------------------
# Shared images and build defaults
# Used by:
#   ./scripts/compose.sh remote
#   ./scripts/compose.sh caddy
#   ./scripts/compose.sh demo
#   ./scripts/compose.sh portable-smoke
#   ./scripts/compose.sh e2e
# -----------------------------------------------------------------------------
S3DESK_IMAGE=ghcr.io/homelabird/s3desk
S3DESK_TAG=0.21v-rc2
POSTGRES_IMAGE=docker.io/library/postgres:15-alpine
MINIO_IMAGE=docker.io/minio/minio:latest
MINIO_MC_IMAGE=docker.io/minio/mc:latest
PYTHON_IMAGE=docker.io/library/python:3.12-alpine
AZURITE_IMAGE=mcr.microsoft.com/azure-storage/azurite:3.33.0
FAKE_GCS_IMAGE=fsouza/fake-gcs-server:1.47.7
RCLONE_VERSION=1.72.0

# -----------------------------------------------------------------------------
# Core remote / Postgres deployment
# Used by:
#   ./scripts/compose.sh remote
#   ./scripts/compose.sh caddy
# Required for a real remote deployment:
#   API_TOKEN
#   POSTGRES_PASSWORD
#   S3DESK_BIND_ADDRESS
# -----------------------------------------------------------------------------
S3DESK_BIND_ADDRESS=127.0.0.1
S3DESK_PORT=8080
API_TOKEN=replace-with-a-long-random-token
POSTGRES_PASSWORD=replace-with-a-strong-db-password
POSTGRES_USER=s3desk
POSTGRES_DB=s3desk

# -----------------------------------------------------------------------------
# Public hostname / reverse proxy
# Used by:
#   ./scripts/compose.sh remote
#   ./scripts/compose.sh caddy
# Replace these when serving S3Desk behind a hostname or reverse proxy.
# If you only use a private IP / localhost without Caddy, you can clear them.
# -----------------------------------------------------------------------------
EXTERNAL_BASE_URL=https://s3desk.example.com
ALLOWED_HOSTS=s3desk.example.com
S3DESK_DOMAIN=s3desk.example.com

# -----------------------------------------------------------------------------
# Local build only
# Used by:
#   ./scripts/compose.sh dev
# -----------------------------------------------------------------------------
# Prefer an absolute path if you override this.
OCI_CONFIG_MOUNT_DIR=

# -----------------------------------------------------------------------------
# Demo stack
# Used by:
#   ./scripts/compose.sh demo
# -----------------------------------------------------------------------------
S3DESK_DEMO_IMAGE=localhost/s3desk-demo:sqlite
# Demo also uses S3DESK_PORT from the shared section above.
S3DESK_BIND_HOST=127.0.0.1
DEMO_ALLOWED_HOSTS=127.0.0.1,localhost
MINIO_BIND_HOST=127.0.0.1
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
DEMO_PROFILE_NAME=MinIO Demo
DEMO_BUCKET=demo-bucket

# Optional demo seed endpoint overrides.
# Leave blank to derive from the bind host/port settings above.
# When bind hosts use `0.0.0.0` or `::`, derived seed endpoints use loopback
# unless you set explicit reachable endpoints here.
S3DESK_API_BASE=
MINIO_ENDPOINT=
MINIO_INTERNAL_ENDPOINT=
MINIO_PUBLIC_ENDPOINT=

# Optional shared MinIO overrides for demo / portable smoke.
# Leave blank to keep the compose defaults for each stack.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_REGION=

# -----------------------------------------------------------------------------
# Portable smoke and failure smoke
# Used by:
#   ./scripts/run_portable_sqlite_to_postgres_smoke.sh
#   ./scripts/run_portable_postgres_to_sqlite_smoke.sh
#   ./scripts/run_portable_failure_smoke.sh
#   ./scripts/run_portable_postgres_to_sqlite_failure_smoke.sh
# -----------------------------------------------------------------------------
S3DESK_PORTABLE_SMOKE_IMAGE=localhost/s3desk-portable-smoke:dev
PORTABLE_SMOKE_API_TOKEN=portable-token
PORTABLE_SMOKE_SOURCE_DB_BACKEND=sqlite
PORTABLE_SMOKE_TARGET_DB_BACKEND=postgres
PORTABLE_SMOKE_POSTGRES_DB=s3desk
PORTABLE_SMOKE_POSTGRES_USER=s3desk
PORTABLE_SMOKE_POSTGRES_PASSWORD=portable
PORTABLE_SMOKE_PROFILE_NAME=Portable Smoke
PORTABLE_SMOKE_BUCKET=portable-bucket
PORTABLE_SMOKE_FAVORITE_KEY=welcome.txt
PORTABLE_SMOKE_DB_STARTUP_TIMEOUT=60s

# Optional overrides for encrypted/password-protected portable smoke.
# Leave blank to use script defaults or no password.
PORTABLE_SMOKE_SOURCE_ENCRYPTION_KEY=
PORTABLE_SMOKE_TARGET_ENCRYPTION_KEY=
PORTABLE_BUNDLE_CONFIDENTIALITY=clear
PORTABLE_BUNDLE_PASSWORD=
PORTABLE_BUNDLE_EXPORT_PASSWORD=
PORTABLE_BUNDLE_IMPORT_PASSWORD=

# -----------------------------------------------------------------------------
# E2E compose runner
# Used by:
#   ./scripts/compose.sh e2e
# -----------------------------------------------------------------------------
E2E_BASE_URL=http://s3desk:8080
E2E_MINIO_ENDPOINT=http://minio:9000
E2E_AZURITE_ENDPOINT=http://azurite:10000/devstoreaccount1
E2E_GCS_ENDPOINT=http://fake-gcs-server:4443/storage/v1/v1
