# Checked-in compose defaults with no secrets.
# Override these in a local `.env` copied from `.env.example` when you need
# deployment-specific settings or stack-specific overrides.

# Shared release image used by the remote Postgres templates.
S3DESK_IMAGE=ghcr.io/homelabird/s3desk
S3DESK_TAG=0.21v-rc2

# Shared helper images used by demo / smoke / e2e compose stacks.
POSTGRES_IMAGE=docker.io/library/postgres:15-alpine
MINIO_IMAGE=docker.io/minio/minio:latest
MINIO_MC_IMAGE=docker.io/minio/mc:latest
PYTHON_IMAGE=docker.io/library/python:3.12-alpine
AZURITE_IMAGE=mcr.microsoft.com/azure-storage/azurite:3.33.0
FAKE_GCS_IMAGE=fsouza/fake-gcs-server:1.47.7

# Shared build arg for local/demo/smoke images.
RCLONE_VERSION=1.72.0

# -----------------------------------------------------------------------------
# Demo stack (override with your reachable host IP for non-local access)
# -----------------------------------------------------------------------------
DEMO_PUBLIC_HOST=192.168.2.230
S3DESK_BIND_HOST=0.0.0.0
DEMO_ALLOW_REMOTE=true
DEMO_ALLOWED_HOSTS=192.168.2.230,0.0.0.0,127.0.0.1,localhost,::1
MINIO_BIND_HOST=0.0.0.0
EXTERNAL_BASE_URL=http://192.168.2.230:8080
